 <h3>error</h3>\n    }\n\n    return(\n        <div>\n      <h1>Student</h1>\n      {student.length===0?<h3>no student</h3>:\n      (<ul>\n        {student.map((s)=>(\n            <li key={s.id}>\n                {s.sname}---{s.course}----<Link to={`/students/${s.id}`}>info</Link>\n\n            </li>\n       ) )}\n      </ul>)}\n      <Link to=\"/\">Home</Link>\n        </div>\n    )\n}"],"mappings":"AAAA,OAASA,WAAW,CAAEC,WAAW,KAAQ,aAAa,CACtD,OAASC,cAAc,KAAQ,wBAAwB,CACvD,OAASC,SAAS,KAAQ,OAAO,CACjC,OAASC,IAAI,KAAQ,kBAAkB,QAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEvC,MAAO,SAAS,CAAAC,WAAWA,CAAA,CAAE,CACzB,KAAM,CAAAC,QAAQ,CAAEV,WAAW,CAAC,CAAC,CAC7B,KAAM,CAAAW,OAAO,CAACV,WAAW,CAAEW,KAAK,EAAGA,KAAK,CAACD,OAAO,CAAC,CACjD,KAAM,CAAAE,OAAO,CAACZ,WAAW,CAAEW,KAAK,EAAGA,KAAK,CAACC,OAAO,CAAC,CACjD,KAAM,CAAAC,KAAK,CAAEb,WAAW,CAAEW,KAAK,EAAGA,KAAK,CAACE,KAAK,CAAC,CAC9CX,SAAS,CAAC,IAAI,CACVO,QAAQ,CAACR,cAAc,CAAC,CAAC,CAAC,CAC9B,CAAC,CAAC,CAACQ,QAAQ,CAAC,CAAC,CAEb,GAAGG,OAAO,CAAC,CACP,mBAAOP,IAAA,OAAAS,QAAA,CAAI,YAAU,CAAI,CAAC,EAE9B,GAAGD,KAAK,CAAC,CACL,mBAAOR,IAAA,OAAAS,QAAA,CAAI,OAAK,CAAI,CAAC,CACzB,CAEA,mBACIP,KAAA,QAAAO,QAAA,eACFT,IAAA,OAAAS,QAAA,CAAI,SAAO,CAAI,CAAC,CACfJ,OAAO,CAACK,MAAM,GAAG,CAAC,cAACV,IAAA,OAAAS,QAAA,CAAI,YAAU,CAAI,CAAC,cACtCT,IAAA,OAAAS,QAAA,CACEJ,OAAO,CAACM,GAAG,CAAEC,CAAC,eACXV,KAAA,OAAAO,QAAA,EACKG,CAAC,CAACC,KAAK,CAAC,KAAG,CAACD,CAAC,CAACE,MAAM,CAAC,MAAI,cAAAd,IAAA,CAACF,IAAI,EAACiB,EAAE,CAAE,aAAaH,CAAC,CAACI,EAAE,EAAG,CAAAP,QAAA,CAAC,MAAI,CAAM,CAAC,GAD/DG,CAAC,CAACI,EAGP,CACP,CAAC,CACA,CAAE,cACNhB,IAAA,CAACF,IAAI,EAACiB,EAAE,CAAC,GAAG,CAAAN,QAAA,CAAC,MAAI,CAAM,CAAC,EACjB,CAAC,CAEd","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}